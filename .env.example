# Required: PostgreSQL connection string for Prisma + app runtime.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/common_collective"

# Required in production: canonical external app URL (https).
# Local development default:
NEXTAUTH_URL="http://localhost:3000"

# Required: long random secret for session/JWT signing.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Optional (host-specific): direct non-pooled DB URL for migration jobs.
# Useful on providers where runtime DATABASE_URL uses pooling/proxying.
# DATABASE_URL_NON_POOLING="postgresql://postgres:postgres@localhost:5432/common_collective"

# Optional: SMTP settings for outbox email dispatch
# SMTP_HOST="smtp.mailprovider.com"
# SMTP_PORT="587"
# SMTP_USER="smtp-user"
# SMTP_PASS="smtp-password"
# EMAIL_FROM="The Common Collective <hello@yourdomain.com>"

# Required to authorize /api/internal/email/dispatch
# Generate with: openssl rand -hex 32
# EMAIL_DISPATCH_TOKEN="replace-with-random-token"
