# Copy to .env and fill in values. Never commit real secrets.
# This file is tracked; .env is gitignored.

# -----------------------------------------------------------------------------
# Core (required in production — see lib/env/production-checks.ts)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Public site URL (must match deployed origin; used by NextAuth and email deep links)
NEXTAUTH_URL=https://www.example.com

# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# -----------------------------------------------------------------------------
# Email (required for transactional email + outbox dispatch cron)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="The Common Collective <noreply@example.com>"

# Bearer token for POST /api/internal/email/dispatch and reminders dispatch
EMAIL_DISPATCH_TOKEN=

# -----------------------------------------------------------------------------
# Apple Push Notification service (optional — push is skipped if unset)
# -----------------------------------------------------------------------------
# Create an APNs Auth Key in Apple Developer; use .p8 contents (PEM).
# Use literal \n in single-line env, or multiline in your host's secret UI.
APNS_AUTH_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=space.thecommoncollective.app
APNS_PRIVATE_KEY=
# true = sandbox (Xcode dev / TestFlight often); false = production App Store builds
APNS_USE_SANDBOX=true

# -----------------------------------------------------------------------------
# Optional / defaults
# -----------------------------------------------------------------------------
# NODE_ENV=production
